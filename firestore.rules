rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "beraniranjan722@gmail.com" && request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isFaculty() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'faculty' || 
              request.auth.token.email == "beraniranjan722@gmail.com");
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && 
                      isValidString(request.resource.data.displayName, 1, 100) &&
                      (request.resource.data.role == 'student' || 
                       (request.auth.token.email == "beraniranjan722@gmail.com" && request.resource.data.role == 'admin'));
      allow update: if (isOwner(userId) && 
                        request.resource.data.role == resource.data.role &&
                        request.resource.data.active == resource.data.active &&
                        isValidString(request.resource.data.displayName, 1, 100)) || 
                      isAdmin();
      allow delete: if isAdmin();
    }

    match /batches/{batchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /attendance/{attId} {
      allow read: if isAdmin() || (isAuthenticated() && (request.auth.uid == resource.data.studentId || isFaculty()));
      allow create: if isAuthenticated() && 
                      request.auth.uid == request.resource.data.studentId &&
                      request.resource.data.timestamp == request.time;
      allow update, delete: if isAdmin() || isFaculty();
    }

    match /marks/{markId} {
      allow read: if isAdmin() || (isAuthenticated() && (request.auth.uid == resource.data.studentId || isFaculty()));
      allow write: if isAdmin() || isFaculty();
    }

    match /assignments/{asgnId} {
      allow read: if isAuthenticated();
      allow create: if isFaculty() && 
                      isValidString(request.resource.data.title, 1, 200);
      allow update, delete: if isAdmin() || isFaculty();
    }

    match /submissions/{subId} {
      allow read: if isAdmin() || (isAuthenticated() && (request.auth.uid == resource.data.studentId || isFaculty()));
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.studentId;
      allow update: if isAdmin() || 
                      (isAuthenticated() && request.auth.uid == resource.data.studentId && 
                       request.resource.data.marks == resource.data.marks) ||
                      isFaculty();
      allow delete: if isAdmin();
    }

    match /labs/{labId} {
      allow read: if isAuthenticated();
      allow write: if isFaculty();
    }

    match /lab_submissions/{labSubId} {
      allow read: if isAdmin() || (isAuthenticated() && (request.auth.uid == resource.data.studentId || isFaculty()));
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.studentId;
      allow update: if isAdmin() || 
                      (isAuthenticated() && request.auth.uid == resource.data.studentId && 
                       request.resource.data.score == resource.data.score) ||
                      isFaculty();
      allow delete: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if isAuthenticated() && (
        resource.data.visibility == 'public' || 
        resource.data.visibility == 'unlisted' || 
        resource.data.facultyId == request.auth.uid || 
        isAdmin()
      );
      allow write: if isFaculty() && (
        request.resource.data.facultyId == request.auth.uid || 
        isAdmin()
      );
    }

    match /attendance_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isFaculty() && request.auth.uid == request.resource.data.facultyId;
      allow update, delete: if isAdmin() || isFaculty();
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && 
                      isValidString(request.resource.data.title, 1, 200) &&
                      isValidString(request.resource.data.message, 1, 1000) &&
                      request.resource.data.read == false &&
                      request.resource.data.createdAt == request.time;
      allow update: if isOwner(resource.data.userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
